{
  "version": 2,
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/scan.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/results/[domain].js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/scan",
      "dest": "/api/scan.js"
    },
    {
      "src": "/api/results/(.*)",
      "dest": "/api/results/[domain].js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ],
  "functions": {
    "api/scan.js": {
      "maxDuration": 300
    },
    "api/results/[domain].js": {
      "maxDuration": 10
    }
  }
}
